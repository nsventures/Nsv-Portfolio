{
  "name": "nsvportfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "import:tours": "node scripts/import-tours.mjs",
    "parse:tours": "node scripts/parse-vr-csv.mjs",
    "delete:videos": "node --env-file=.env.local scripts/delete-all-videos.mjs",
    "delete:vr-tours": "node --env-file=.env.local scripts/delete-all-vr-tours.mjs",
    "test:authyo": "node --env-file=.env.local scripts/test-authyo.mjs",
    "backfill:youtube-dates": "node --env-file=.env.local scripts/backfill-youtube-dates.mjs",
    "delete:orphan-thumbs": "node --env-file=.env.local scripts/delete-all-videos.mjs --orphans-only",
    "dev:import": "node --env-file=.env.local server/bulk-import.mjs",
    "start:import": "node server/bulk-import.mjs",
    "dev:free": "node scripts/free-dev-ports.mjs",
    "predev:all": "node scripts/free-dev-ports.mjs",
    "dev:all": "concurrently -k -n vite,import -c cyan,magenta npm:dev npm:dev:import",
    "dev-all": "npm run dev:all"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/gsap": "^1.20.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "country-telephone-data": "^0.6.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.52.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
